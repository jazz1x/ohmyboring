{
  "$schema": "https://raw.githubusercontent.com/jazz1x/ohmyboring/main/boring.schema.json",
  "schema_version": 1,
  "note_lang": "auto",
  "embed_model": "bge-m3",
  "embed_dim": 1024,
  "repos": [
    {"match": "your-company", "origin": "company", "name": "work"},
    {"match": "your-name/code", "origin": "personal", "name": "personal"}
  ],
  "agents": [
    {
      "id": "claude-code",
      "enabled": true,
      "adapter": "session-end",
      "format": "claude-json",
      "paths": ["~/.claude/projects"]
    },
    {
      "id": "cursor",
      "enabled": true,
      "adapter": "mcp-only"
    },
    {
      "id": "codex",
      "enabled": true,
      "adapter": "mcp-only"
    }
  ]
}

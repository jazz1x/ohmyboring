# ── 시크릿 ──────────────────────────────────────────────
.env
.env.local

# ── 런타임 데이터 (DB 블롭·캐시·개인노트) — eval 소스만 보존 ──
data/*
!data/eval/
data/eval/*.db

# ── 임베디드 surreal(이제 서버모드) + Rust 빌드 ──────────
drudge/target/
drudge/data/

# ── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# ── OS / 에디터 ─────────────────────────────────────────
.DS_Store
*.swp

# ── vault: 개인 증류물(raw)·컴파일 산출물(wiki)은 추적 제외 ───────────────
# 구조(.gitkeep)·거버넌스(.rules)·예시(example.md) 템플릿만 보존. 개인 노트는 누수 방지.
vault/raw/*
vault/wiki/*
!vault/raw/.gitkeep
!vault/raw/example.md
!vault/wiki/.gitkeep
!vault/wiki/wiki-0000.md
vault/.obsidian/
.obsidian/

# 개인 문서·작업 핸드오프(회사명 등 포함) — 공개 제외
docs/*

# 개인 정책 설정 — 예시 파일(boring.example.json)만 추적
boring.json

# To use, copy:  cp .env.example .env
#
# The core (postgres + drudge) does *not* need .env — the defaults are baked into docker-compose.yml.
# This file optionally supplies (1) Slack tokens (2) LLM runtime/model swap.
# Policy (note language, repo rules, source dirs) lives in boring.json — edit that instead.

# ── Slack (optional — only when enabling the hermes-agent assistant) ─────────────────────────────────
# Create a Slack app → turn on Socket Mode → issue an App-Level Token + Bot Token.
# Without these, the agent stays disconnected from Slack (irrelevant to core ingest/recall).
SLACK_APP_TOKEN="<your-app-level-token>"
SLACK_BOT_TOKEN="<your-bot-token>"

# ── Core-only startup (optional) ─────────────────────────────────────────────────────────────────────
# start.sh skips the optional hermes-agent automatically when its image is absent. Set this to force
# core-only (drudge [+ postgres]) even if a hermes-agent image exists, and to silence the skip notice.
# OMB_CORE_ONLY=1

# ── Graph + vector accelerator (optional — default off) ──────────────────────────────────────────────
# OMB_VECTOR=off   # on = pgvector graph+vector (similarity search + GraphRAG); off = embed-only kernel
#                  # (DRUDGE_VECTOR = deprecated alias, still honored)

# ── LLM connection — configure in boring.json, NOT here ──────────────────────────────────────────────
# The LLM provider/base_url/model/embed_model now live in boring.json's `llm` block (the SSOT):
#   "llm": { "provider": "ollama|lmstudio|openai-compatible", "base_url": ".../v1",
#            "model": "...", "embed_model": "...", "embed_dim": 1024, "bootstrap": "auto|manual" }
# drudge speaks OpenAI-compatible /v1 → Ollama, LM Studio, vLLM, llama.cpp server, remote OpenAI, etc.
#
# The vars below are OPTIONAL runtime OVERRIDES (env wins over boring.json). OMB_* is canonical;
# DRUDGE_* is a deprecated alias (still read, prints a one-time warning). embed_model is NOT
# env-overridable — it is the engine's policy SSOT (boring.json only).
# OMB_LLM_BASE_URL=http://host.docker.internal:11434/v1   # override the configured base_url
# OMB_LLM_MODEL=gemma4:12b                                # override the synthesis model
# OMB_LLM_API_KEY=                                        # API key when api_key_env points here (auth providers)
#   NOTE: to run the `drudge` binary directly on the HOST (e.g. selftest), set
#         OMB_LLM_BASE_URL=http://localhost:11434/v1 — host.docker.internal resolves only in-container.
# PG_DSN=postgresql://boring:boring@postgres:5432/boring

# ── Claude Code recall hook (optional — defaults are conservative) ───────────────────────────────────
# These cap the context injected into every Claude Code prompt to avoid token explosions.
# RECALL_MAX_RESULTS=3
# RECALL_MAX_TOKENS=1500
# RECALL_TIMEOUT=5
# RECALL_RETRIES=1

# ── Ollama / repo paths (optional — defaults usually work) ──────────────────────────────────────────
# OLLAMA_HOST=http://localhost:11434              # host-side default (resolves from a host shell). In-container, use http://host.docker.internal:11434
# OMB_HOME=/Users/you/oh-my-boring                 # only needed if you cloned somewhere unusual

# ── drudge container uid/gid (optional — native Linux only) ──────────────────────────────────────────
# On native Linux the drudge container writes the host-owned vault/ as uid:gid (default 10001:10001),
# which can EACCES. Set these to your host user so writes are owned by you. macOS (Docker Desktop
# uid-remaps) is unaffected, so leave them unset there. Linux: $(id -u):$(id -g).
# DRUDGE_UID=1000
# DRUDGE_GID=1000

# ── Hermes agent host mapping (optional — only when running hermes-agent) ──────────────────────────
# The hermes-agent container maps ~/.hermes to /opt/data. Set these to your host uid/gid so files are
# owned by you instead of root or the container default. macOS example: 501:20. Linux: $(id -u):$(id -g).
# HERMES_UID=501
# HERMES_GID=20

# ── Deprecated: company/personal tagging and source dirs now live in boring.json ────────────────────
# DRUDGE_COMPANY_SUBSTR, DISTILL_COMPANY_CWD, DRUDGE_SOURCE_DIRS, and DRUDGE_NOTE_LANG are read only
# when boring.json is missing, and they print a deprecation warning. Migrate via scripts/migrate-config.sh.

# 복사해서 사용:  cp .env.example .env
#
# 코어(postgres + drudge)는 .env 가 *필요 없다* — 기본값은 docker-compose.yml 에 박혀 있다.
# 이 파일은 (1) Slack 토큰 (2) LLM 런타임/모델 교체 (3) 회사 태깅 을 선택적으로 공급한다.

# ── Slack (선택 — hermes-agent 비서 켤 때만) ─────────────────────────────────
# Slack 앱 생성 → Socket Mode ON → App-Level Token + Bot Token 발급.
# 없으면 에이전트가 Slack 미연결(코어 적재·회수와 무관).
SLACK_APP_TOKEN=<your-app-level-token>
SLACK_BOT_TOKEN=<your-bot-token>

# ── LLM 런타임/모델 (선택 — 기본 = 호스트 Ollama gemma4:12b + bge-m3) ─────────
# drudge 는 OpenAI-호환 /v1 로 말한다 → Ollama·LM Studio·vLLM·llama.cpp server 등 무엇이든.
# DRUDGE_LLM_BASE_URL=http://host.docker.internal:11434/v1   # 기본(Ollama). LM Studio: .../v1 (보통 1234)
# DRUDGE_LLM_MODEL=gemma4:12b                                # 합성 모델 (아무 모델이나)
# DRUDGE_EMBED_MODEL=bge-m3                                  # 임베딩 (1024d)
# DRUDGE_LLM_API_KEY=                                        # 인증 필요한 provider(OpenAI 등)만. Ollama/LM Studio 불필요
# PG_DSN=postgresql://boring:boring@postgres:5432/boring

# ── 회사/개인 태깅 (선택 — 기본 빈값 = 모든 문서 origin=personal) ─────────────
# 특정 경로 문서를 origin=company 로 태깅 + ingest 제외. 코드 수정 0, 토큰만 꽂으면 됨.
# DRUDGE_COMPANY_SUBSTR=acme:acme-kb          # Rust ingest/origin/audit (경로 substring)
# DISTILL_COMPANY_CWD=acme                    # 세션 증류 훅 (cwd substring → origin=company)

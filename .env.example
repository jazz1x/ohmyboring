# 복사해서 사용:  cp .env.example .env
#
# v2 핵심: 코어 엔진(postgres + hermes-rs)은 .env 가 *필요 없다* — 모든 설정은
# docker-compose.yml 에 박혀 있다. 이 파일은 ジョセフ(Slack 게이트웨이) 토큰만 공급한다.
# Slack 안 쓰면 비워둬도 코어(적재·회수)는 그대로 돈다.

# ── ジョセフ Slack 게이트웨이 (선택) ─────────────────────────────────────────
# Slack 앱 생성 → Socket Mode ON → App-Level Token + Bot Token 발급.
# 없으면 joseph 컨테이너만 미연결(코어 엔진과 무관).
SLACK_APP_TOKEN=<your-app-level-token>
SLACK_BOT_TOKEN=<your-bot-token>

# ── 격리/태깅 (선택 — 기본 빈값 = 모든 문서 origin=personal) ─────────────────
# 특정 경로의 문서를 origin=company 로 태깅 + ingest 에서 제외하고 싶을 때 토큰을 ':' 로 나열.
# 다운스트림 fork 는 코드 수정 없이 여기 토큰만 꽂으면 회사 레이어가 켜진다.
# HERMES_COMPANY_SUBSTR=acme:acme-kb          # Rust ingest/origin/audit (경로 substring)
# DISTILL_COMPANY_CWD=acme                    # 세션 증류 훅 (cwd substring → origin=company)

# ── 선택 오버라이드 (기본값은 docker-compose.yml 의 hermes-rs 환경) ──────────
# HERMES_LLM_MODEL=gemma4:12b                              # 합성 모델 (think=false 고정)
# HERMES_EMBED_MODEL=bge-m3                                # 임베딩 (1024d)
# OLLAMA_HOST=http://host.docker.internal:11434            # 호스트 Ollama
# PG_DSN=postgresql://olympus:olympus@postgres:5432/olympus
